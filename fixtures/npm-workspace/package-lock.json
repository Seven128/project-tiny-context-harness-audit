{
  "name": "ty-context-workspace-fixture",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "ty-context-workspace-fixture",
      "version": "1.0.0",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@fixture/app": {
      "resolved": "packages/app",
      "link": true
    },
    "node_modules/@fixture/core": {
      "resolved": "packages/core",
      "link": true
    },
    "packages/app": {
      "name": "@fixture/app",
      "version": "1.0.0",
      "dependencies": {
        "@fixture/core": "1.0.0"
      }
    },
    "packages/core": {
      "name": "@fixture/core",
      "version": "1.0.0"
    }
  }
}
